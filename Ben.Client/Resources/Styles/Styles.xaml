                        Value="Fill"/>
        </Style>

        <Style x:Key="ThemedCard"
               TargetType="Border">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource CardBackgroundBrush}"/>
                <Setter Property="Stroke"
                        Value="{DynamicResource BorderColor}"/>
                <Setter Property="StrokeThickness"
                        Value="{DynamicResource BorderThickness}"/>
        </Style>

        <Style x:Key="ThemedCardCompact"
               TargetType="Border"
               BasedOn="{StaticResource ThemedCard}">
                <Setter Property="Padding"
                        Value="{DynamicResource SpacingSm}"/>
