        <Style x:Key="DividerH"
               TargetType="BoxView">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource DividerColor}"/>
                <Setter Property="HeightRequest"
                        Value="{DynamicResource DividerThickness}"/>
                <Setter Property="HorizontalOptions"
                        Value="Fill"/>
        </Style>

        <Style x:Key="DividerV"
               TargetType="BoxView">
                <Setter Property="BackgroundColor"
                        Value="{DynamicResource GridLineColor}"/>
                <Setter Property="WidthRequest"
                        Value="{DynamicResource DividerThickness}"/>
