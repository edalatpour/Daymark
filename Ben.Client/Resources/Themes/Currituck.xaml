<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Ben.Resources.Themes.Currituck">

    <!-- Currituck Lighthouse — Brick Red -->

    <Color x:Key="Paper">#F9F6F2</Color>
    <Color x:Key="WritingPaper">#FFFFFF</Color>

    <Color x:Key="Ink">#2B2B2B</Color>
    <Color x:Key="Line">#D8C8B0</Color>

    <Color x:Key="Accent">#C2B280</Color>
    <Color x:Key="Link">#8B2E2E</Color>

    <Color x:Key="UserText">#000000</Color>

    <Color x:Key="PageBackgroundBrush">#F9F6F2</Color>
    <Color x:Key="CardBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="InkBrush">#2B2B2B</Color>
    <Color x:Key="SecondaryInkBrush">#7A6E63</Color>
    <Color x:Key="GlyphBrush">#8B2E2E</Color>
    <Color x:Key="AccentBrush">#C2B280</Color>
    <Color x:Key="SelectionBrush">#80C2B280</Color>
    <Color x:Key="HighlightBrush">#33C2B280</Color>
    <Color x:Key="HeaderBackgroundBrush">#8B2E2E</Color>
    <Color x:Key="HeaderForegroundBrush">#FFFFFF</Color>
    <Color x:Key="CheckboxStrokeBrush">#8B2E2E</Color>
    <Color x:Key="CheckboxFillBrush">#C2B280</Color>
    <Color x:Key="BorderColor">#A0522D</Color>
    <Color x:Key="GridLineColor">#D8C8B0</Color>
    <Color x:Key="DividerColor">#D8C8B0</Color>
    <x:Double x:Key="BorderThickness">1</x:Double>
    <x:Double x:Key="DividerThickness">1</x:Double>
    <x:Double x:Key="CornerRadius">6</x:Double>
    <Color x:Key="ButtonTextOnAccent">#FFFFFF</Color>
    <Color x:Key="ButtonTextOnInk">#FFFFFF</Color>
    <x:String x:Key="HeaderPatternStyle">Banded</x:String>
    <x:Double x:Key="HeaderPatternOpacity">0.08</x:Double>
    <x:Double x:Key="PatternStripeWidth">6</x:Double>
    <x:Double x:Key="PatternAngle">0</x:Double>
    <x:Double x:Key="SpacingXs">4</x:Double>
    <x:Double x:Key="SpacingSm">8</x:Double>
    <x:Double x:Key="SpacingMd">12</x:Double>
    <x:Double x:Key="SpacingLg">16</x:Double>
    <x:Double x:Key="SpacingXl">24</x:Double>
    <x:Double x:Key="RadiusSmall">4</x:Double>
    <x:Double x:Key="RadiusMedium">6</x:Double>
    <x:Double x:Key="RadiusLarge">10</x:Double>
    <CornerRadius x:Key="ListCardCornerRadius">12</CornerRadius>
    <x:Double x:Key="GridLineOpacity">0.28</x:Double>
    <x:String x:Key="GridMode">Soft</x:String>
    <x:String x:Key="ThemeHeaderFont">SourceSerifPro-SemiBold</x:String>
    <x:String x:Key="ThemeDateNumberFont">SourceSerifPro-SemiBold</x:String>
    <x:String x:Key="ThemeDateDayFont">NotoSerif-Regular</x:String>

</ResourceDictionary>
