<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Ben.Resources.Themes.OakIsland">

    <!-- Oak Island Lighthouse — Tri-Band Gray -->
    <!-- ThemeHeaderFont uses SF Pro Rounded on Apple platforms, Roboto elsewhere -->

    <Color x:Key="Paper">#F2F2F2</Color>
    <Color x:Key="WritingPaper">#FFFFFF</Color>

    <Color x:Key="Ink">#1E1E1E</Color>
    <Color x:Key="Line">#D0D0D0</Color>

    <Color x:Key="Accent">#B0B0B0</Color>
    <Color x:Key="Link">#2E2E2E</Color>

    <Color x:Key="UserText">#000000</Color>

    <Color x:Key="PageBackgroundBrush">#F2F2F2</Color>
    <Color x:Key="CardBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="InkBrush">#1E1E1E</Color>
    <Color x:Key="SecondaryInkBrush">#808080</Color>
    <Color x:Key="GlyphBrush">#1E1E1E</Color>
    <Color x:Key="AccentBrush">#B0B0B0</Color>
    <Color x:Key="SelectionBrush">#80B0B0B0</Color>
    <Color x:Key="HighlightBrush">#33B0B0B0</Color>
    <Color x:Key="HeaderBackgroundBrush">#2E2E2E</Color>
    <Color x:Key="HeaderForegroundBrush">#FFFFFF</Color>
    <Color x:Key="CheckboxStrokeBrush">#A0A0A0</Color>
    <Color x:Key="CheckboxFillBrush">#2E2E2E</Color>
    <Color x:Key="BorderColor">#A0A0A0</Color>
    <Color x:Key="GridLineColor">#D0D0D0</Color>
    <Color x:Key="DividerColor">#D0D0D0</Color>
    <x:Double x:Key="BorderThickness">1</x:Double>
    <x:Double x:Key="DividerThickness">1</x:Double>
    <x:Double x:Key="CornerRadius">6</x:Double>
    <x:String x:Key="ThemeHeaderFont">
        <OnPlatform x:TypeArguments="x:String">
            <On Platform="iOS,MacCatalyst"
                    Value="SFProRounded-Medium"/>
            <On Platform="Android,WinUI"
                    Value="Roboto"/>
        </OnPlatform>
    </x:String>
    <x:String x:Key="ThemeDateNumberFont">
        <OnPlatform x:TypeArguments="x:String">
            <On Platform="iOS,MacCatalyst"
                    Value="SFProRounded-Medium"/>
            <On Platform="Android,WinUI"
                    Value="Roboto"/>
        </OnPlatform>
    </x:String>
    <x:String x:Key="ThemeDateDayFont">Roboto</x:String>

</ResourceDictionary>
