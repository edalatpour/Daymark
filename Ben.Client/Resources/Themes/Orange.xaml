<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Ben.Resources.Themes.Orange">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Paper">#F7F0ED</Color>
    <Color x:Key="WritingPaper">#FFFFFF</Color>

    <Color x:Key="Ink">#693402</Color>
    <Color x:Key="Line">#D9BEB3</Color>

    <Color x:Key="Accent">#B46A04</Color>
    <Color x:Key="Link">#B46A04</Color>

    <Color x:Key="UserText">#000000</Color>

    <Color x:Key="PageBackgroundBrush">#F7F0ED</Color>
    <Color x:Key="CardBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="InkBrush">#693402</Color>
    <Color x:Key="SecondaryInkBrush">#B49A81</Color>
    <Color x:Key="GlyphBrush">#693402</Color>
    <Color x:Key="AccentBrush">#B46A04</Color>
    <Color x:Key="SelectionBrush">#80B46A04</Color>
    <Color x:Key="HighlightBrush">#33B46A04</Color>
    <Color x:Key="HeaderBackgroundBrush">#693402</Color>
    <Color x:Key="HeaderForegroundBrush">#FFFFFF</Color>
    <Color x:Key="CheckboxStrokeBrush">#693402</Color>
    <Color x:Key="CheckboxFillBrush">#B46A04</Color>
    <Color x:Key="BorderColor">#D9BEB3</Color>
    <Color x:Key="GridLineColor">#D9BEB3</Color>
    <Color x:Key="DividerColor">#D9BEB3</Color>
    <x:Double x:Key="BorderThickness">1</x:Double>

    <x:Double x:Key="CardBorderThickness">0</x:Double>
    <x:Double x:Key="DividerThickness">1</x:Double>
    <x:Double x:Key="CornerRadius">4</x:Double>
    <CornerRadius x:Key="ListCardCornerRadius">8</CornerRadius>
    <x:String x:Key="ThemeHeaderFont">Times New Roman</x:String>
    <x:String x:Key="ThemeDateNumberFont">Times New Roman</x:String>
    <x:String x:Key="ThemeDateDayFont">Times New Roman</x:String>
    <x:String x:Key="RootGridBackground"></x:String>
    <x:String x:Key="RootGridBackgroundAspect">Tile</x:String>

</ResourceDictionary>
