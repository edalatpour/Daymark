    <x:Double x:Key="CardBorderThickness">1</x:Double>
    <x:Double x:Key="DividerThickness">1</x:Double>
    <x:Double x:Key="CornerRadius">4</x:Double>
    <CornerRadius x:Key="ListCardCornerRadius">0</CornerRadius>
    <x:String x:Key="ThemeHeaderFont">Times New Roman</x:String>
    <x:String x:Key="ThemeDateNumberFont">Times New Roman</x:String>
    <x:String x:Key="ThemeDateDayFont">Times New Roman</x:String>
