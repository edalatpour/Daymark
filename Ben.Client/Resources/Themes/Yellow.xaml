    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Paper">#F7F5ED</Color>
    <Color x:Key="WritingPaper">#FFFFFF</Color>

    <Color x:Key="Ink">#696402</Color>
    <Color x:Key="Line">#D9D4B3</Color>

    <Color x:Key="Accent">#B4A704</Color>
    <Color x:Key="Link">#B4A704</Color>

    <Color x:Key="UserText">#000000</Color>

    <Color x:Key="PageBackgroundBrush">#F7F5ED</Color>
    <Color x:Key="CardBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="InkBrush">#696402</Color>
