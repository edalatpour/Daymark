    x:Class="Ben.Resources.Themes.Blue">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Paper">#EDF1F7</Color>
    <Color x:Key="WritingPaper">#FFFFFF</Color>

    <Color x:Key="Ink">#022069</Color>
    <Color x:Key="Line">#B3C1D9</Color>

    <Color x:Key="Accent">#0440B4</Color>
    <Color x:Key="Link">#0440B4</Color>

    <Color x:Key="UserText">#000000</Color>

    <Color x:Key="PageBackgroundBrush">#EDF1F7</Color>
    <Color x:Key="CardBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="InkBrush">#022069</Color>
    <Color x:Key="SecondaryInkBrush">#8190B4</Color>
