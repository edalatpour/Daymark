<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Ben.Resources.Themes.Purple">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Paper">#F3EDF7</Color>
    <Color x:Key="WritingPaper">#FFFFFF</Color>

    <Color x:Key="Ink">#3F0269</Color>
    <Color x:Key="Line">#C3B3D9</Color>

    <Color x:Key="Accent">#6A04B4</Color>
    <Color x:Key="Link">#6A04B4</Color>

    <Color x:Key="UserText">#000000</Color>

    <Color x:Key="PageBackgroundBrush">#F3EDF7</Color>
    <Color x:Key="CardBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="InkBrush">#3F0269</Color>
    <Color x:Key="SecondaryInkBrush">#9F81B4</Color>
    <Color x:Key="GlyphBrush">#3F0269</Color>
    <Color x:Key="AccentBrush">#6A04B4</Color>
    <Color x:Key="SelectionBrush">#806A04B4</Color>
    <Color x:Key="HighlightBrush">#336A04B4</Color>
    <Color x:Key="HeaderBackgroundBrush">#3F0269</Color>
    <Color x:Key="HeaderForegroundBrush">#FFFFFF</Color>
    <Color x:Key="CheckboxStrokeBrush">#3F0269</Color>
    <Color x:Key="CheckboxFillBrush">#6A04B4</Color>

    <Color x:Key="BorderColor">#C3B3D9</Color>
    <Color x:Key="GridLineColor">#C3B3D9</Color>
    <Color x:Key="DividerColor">#C3B3D9</Color>
    <x:Double x:Key="BorderThickness">1</x:Double>

    <x:Double x:Key="CardBorderThickness">0</x:Double>
    <x:Double x:Key="DividerThickness">1</x:Double>
    <x:Double x:Key="CornerRadius">4</x:Double>
    <CornerRadius x:Key="ListCardCornerRadius">8</CornerRadius>
    <x:String x:Key="ThemeHeaderFont">Times New Roman</x:String>
    <x:String x:Key="ThemeDateNumberFont">Times New Roman</x:String>
    <x:String x:Key="ThemeDateDayFont">Times New Roman</x:String>
    <x:String x:Key="RootGridBackground"></x:String>
    <x:String x:Key="RootGridBackgroundAspect">Tile</x:String>

</ResourceDictionary>
