<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Ben.Resources.Themes.CapeLookout">

    <!-- Cape Lookout Lighthouse — Diamond Black / White -->

    <Color x:Key="Paper">#F7F7F7</Color>
    <Color x:Key="WritingPaper">#FFFFFF</Color>

    <Color x:Key="Ink">#1A1A1A</Color>
    <Color x:Key="Line">#CFCFCF</Color>

    <Color x:Key="Accent">#333333</Color>
    <Color x:Key="Link">#000000</Color>

    <Color x:Key="UserText">#000000</Color>

    <Color x:Key="PageBackgroundBrush">#F7F7F7</Color>
    <Color x:Key="CardBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="InkBrush">#1A1A1A</Color>
    <Color x:Key="SecondaryInkBrush">#767676</Color>
    <Color x:Key="GlyphBrush">#000000</Color>
    <Color x:Key="AccentBrush">#333333</Color>
    <Color x:Key="SelectionBrush">#80333333</Color>
    <Color x:Key="HighlightBrush">#33333333</Color>
    <Color x:Key="HeaderBackgroundBrush">#000000</Color>
    <Color x:Key="HeaderForegroundBrush">#FFFFFF</Color>
    <Color x:Key="CheckboxStrokeBrush">#333333</Color>
    <Color x:Key="CheckboxFillBrush">#000000</Color>
    <Color x:Key="BorderColor">#333333</Color>
    <Color x:Key="GridLineColor">#CFCFCF</Color>
    <Color x:Key="DividerColor">#CFCFCF</Color>
    <x:Double x:Key="BorderThickness">1</x:Double>
    <x:Double x:Key="DividerThickness">1</x:Double>
    <x:Double x:Key="CornerRadius">5</x:Double>
    <Color x:Key="ButtonTextOnAccent">#FFFFFF</Color>
    <Color x:Key="ButtonTextOnInk">#FFFFFF</Color>
    <x:String x:Key="HeaderPatternStyle">Diamond</x:String>
    <x:Double x:Key="HeaderPatternOpacity">0.09</x:Double>
    <x:Double x:Key="PatternStripeWidth">12</x:Double>
    <x:Double x:Key="PatternAngle">45</x:Double>
    <x:Double x:Key="SpacingXs">4</x:Double>
    <x:Double x:Key="SpacingSm">8</x:Double>
    <x:Double x:Key="SpacingMd">12</x:Double>
    <x:Double x:Key="SpacingLg">16</x:Double>
    <x:Double x:Key="SpacingXl">24</x:Double>
    <x:Double x:Key="RadiusSmall">1</x:Double>
    <x:Double x:Key="RadiusMedium">2</x:Double>
    <x:Double x:Key="RadiusLarge">4</x:Double>
    <CornerRadius x:Key="ListCardCornerRadius">0</CornerRadius>
    <x:Double x:Key="GridLineOpacity">0.40</x:Double>
    <x:String x:Key="GridMode">Strong</x:String>
    <x:String x:Key="ThemeHeaderFont">Montserrat-SemiBold</x:String>
    <x:String x:Key="ThemeDateNumberFont">Montserrat-SemiBold</x:String>
    <x:String x:Key="ThemeDateDayFont">Inter-Regular</x:String>

</ResourceDictionary>
