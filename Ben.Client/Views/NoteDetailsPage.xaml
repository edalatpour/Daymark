<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.NoteDetailsPage"
             Title="Note Details">

    <Grid Style="{DynamicResource PaperRootGrid}">

        <Grid Padding="16"
              HorizontalOptions="Fill"
              RowDefinitions="Auto,*,Auto"
              RowSpacing="12">

            <!-- Header -->
            <Label Grid.Row="0"
                   Text="Note Details"
                   Style="{StaticResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>

            <!-- Form -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <BoxView Grid.ColumnSpan="2"
                         HeightRequest="3"
                         BackgroundColor="{DynamicResource Ink}"/>
                <BoxView Grid.RowSpan="3"
                         WidthRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

                <ScrollView Grid.Row="1"
                            Grid.Column="1"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill">

                    <Grid BackgroundColor="{DynamicResource WritingPaper}"
                          Padding="16"
                          RowDefinitions="*,Auto"
                          RowSpacing="8">

                        <!-- Note text editor -->
                        <Editor x:Name="NoteEditor"
                                Grid.Row="0"
                                Placeholder="Enter note text..."
                                Style="{StaticResource Handwriting}"
                                FontSize="24"
                                BackgroundColor="Transparent"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="160"/>

                    </Grid>

                </ScrollView>

                <BoxView Grid.Row="2"
                         Grid.ColumnSpan="2"
                         HeightRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

            </Grid>

            <!-- Action buttons -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,16,0,0">

                <Button Grid.Column="0"
                        Text="Cancel"
                        Clicked="OnCancelClicked"
                        Style="{DynamicResource SecondaryActionButton}"
                        HeightRequest="44"/>
                <Button Grid.Column="1"
                        Text="Save"
                        Clicked="OnSaveClicked"
                        Style="{DynamicResource PrimaryActionButton}"
                        HeightRequest="44"/>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
