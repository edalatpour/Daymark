<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.NoteDetailsPage"
             Title="Note Details">

    <Grid Style="{DynamicResource PaperRootGrid}">

        <Grid x:Name="LayoutGrid"
              Padding="{DynamicResource SpacingLg}"
              HorizontalOptions="Fill"
              RowDefinitions="Auto,*,Auto"
              RowSpacing="{DynamicResource SpacingMd}">

            <!-- Header -->
            <Label Grid.Row="0"
                   Text="Note Details"
                   Style="{StaticResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>

            <!-- Form -->
            <Border Grid.Row="1"
                    Style="{DynamicResource ThemedCard}"
                    StrokeThickness="{DynamicResource CardBorderThickness}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource ListCardCornerRadius}"/>
                </Border.StrokeShape>

                <ScrollView x:Name="FormScrollView"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill">

                    <Grid BackgroundColor="{DynamicResource WritingPaper}"
                          Padding="{DynamicResource SpacingLg}"
                          RowDefinitions="*,Auto"
                          RowSpacing="8">

                        <!-- Note text editor -->
                        <Editor x:Name="NoteEditor"
                                Grid.Row="0"
                                Placeholder="Enter note text..."
                                Style="{StaticResource HandwritingEditor}"
                                BackgroundColor="Transparent"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="160"/>

                    </Grid>

                </ScrollView>
            </Border>

            <!-- Action buttons -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,12,0,0">

                <Button Grid.Column="0"
                        Text="Cancel"
                        Clicked="OnCancelClicked"
                        Style="{DynamicResource SecondaryActionButton}"
                        HeightRequest="44"/>
                <Button Grid.Column="1"
                        Text="Save"
                        Clicked="OnSaveClicked"
                        Style="{DynamicResource PrimaryActionButton}"
                        HeightRequest="44"/>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
