<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views"
             x:Name="RootPage"
             x:Class="Ben.Views.SearchPage"
             x:DataType="views:SearchPage"
             SafeAreaEdges="All"
             Title="Search Notes">

    <Grid Style="{DynamicResource PaperRootGrid}">
        <Grid Padding="{DynamicResource SpacingLg}"
              HorizontalOptions="Fill"
              RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="{DynamicResource SpacingMd}">

            <Label Grid.Row="0"
                   Text="Search Notes"
                   Style="{DynamicResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*"
                  ColumnSpacing="12">
                <Entry x:Name="SearchEntry"
                       Grid.Column="0"
                       Text="{Binding SearchText, Mode=TwoWay}"
                       Placeholder="Enter text to find in notes"
                       ReturnType="Search"
                       Completed="OnSearchSubmitted"
                       Style="{StaticResource HandwritingEntry}"
                       TextColor="{DynamicResource UserText}"
                       BackgroundColor="Transparent"/>
            </Grid>

            <Border Grid.Row="2"
                    Style="{DynamicResource ThemedCard}"
                    StrokeThickness="{DynamicResource CardBorderThickness}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource ListCardCornerRadius}"/>
                </Border.StrokeShape>
                <Grid BackgroundColor="{DynamicResource WritingPaper}">
                    <ScrollView Margin="0"
                                SafeAreaEdges="SoftInput"
                                BackgroundColor="Transparent">
                        <VerticalStackLayout Spacing="0"
                                             BindableLayout.ItemsSource="{Binding SearchResults}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="views:SearchPage+SearchResultRow">
                                    <ContentView BackgroundColor="{DynamicResource WritingPaper}">
                                        <Grid ColumnDefinitions="*"
                                              RowDefinitions="Auto,6,1"
                                              RowSpacing="0"
                                              ColumnSpacing="8"
                                              Padding="0"
                                              VerticalOptions="Start">
                                            <Label Grid.Row="0"
                                                   Grid.Column="0"
                                                   Margin="{OnPlatform iOS='0,1,0,0', Default='0,3,0,0'}"
                                                   LineBreakMode="WordWrap"
                                                   HorizontalTextAlignment="Start"
                                                   VerticalTextAlignment="Start"
                                                   LineHeight="1"
                                                   Style="{StaticResource Handwriting}"
                                                   FormattedText="{Binding RowText}"/>
                                            <BoxView Grid.Row="2"
                                                     Grid.ColumnSpan="1"
                                                     Style="{DynamicResource DividerSoft}"
                                                     VerticalOptions="End"/>
                                        </Grid>
                                    </ContentView>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>

            <Grid Grid.Row="3"
                  RowDefinitions="Auto"
                  RowSpacing="0"
                  Margin="{DynamicResource FooterTopMargin}">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*"
                      ColumnSpacing="{DynamicResource SpacingMd}">
                    <Button Grid.Column="0"
                            Text="Close"
                            Clicked="OnCancelClicked"
                            Style="{DynamicResource SecondaryActionButton}"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
