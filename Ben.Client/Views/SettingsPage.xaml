<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views"
             x:Class="Ben.Views.SettingsPage"
             x:DataType="views:SettingsPage"
             x:Name="RootSettingsPage"
             Title="Settings">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False"/>
    </Shell.BackButtonBehavior>

    <Grid Style="{DynamicResource PaperRootGrid}">

        <Grid Padding="16"
              HorizontalOptions="Fill"
              RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="12">

            <!-- Header -->
            <Label Grid.Row="0"
                   Text="Settings"
                   Style="{DynamicResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>

            <!-- Form -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <BoxView Grid.ColumnSpan="2"
                         HeightRequest="3"
                         BackgroundColor="{DynamicResource Ink}"/>
                <BoxView Grid.RowSpan="3"
                         WidthRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

                <ScrollView Grid.Row="1"
                            Grid.Column="1"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill">

                    <Grid BackgroundColor="{DynamicResource WritingPaper}"
                          Padding="16"
                          RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="16">

                        <!-- Authentication -->
                        <StackLayout Grid.Row="0" Spacing="8" Padding="4,0,4,4">

                            <!-- Authenticated state: user avatar + email/name (tap = sign out) -->
                            <Grid IsVisible="{Binding AuthViewModel.IsAuthenticated}"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8"
                                  HorizontalOptions="Fill">

                                <Border Grid.Column="0"
                                        WidthRequest="24"
                                        HeightRequest="24"
                                        StrokeThickness="0"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Image Source="{Binding AuthViewModel.UserAvatarSource}"
                                           Aspect="AspectFill"
                                           WidthRequest="24"
                                           HeightRequest="24"/>
                                </Border>

                                <Label Grid.Column="1"
                                       Text="{Binding AuthViewModel.LoginStatusText}"
                                       FontSize="14"
                                       TextColor="{DynamicResource Link}"
                                       TextDecorations="Underline"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Start">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignOutTapped"/>
                                    </Label.GestureRecognizers>
                                </Label>

                            </Grid>

                            <!-- Not-authenticated state: three sign-in options -->
                            <!-- Image files required in Resources/Images:
                                 ms_symbollockup_signin_dark.png  — from https://learn.microsoft.com/en-us/entra/identity-platform/howto-add-branding-in-apps
                                 signin_with_apple.png            — from https://developer.apple.com/design/human-interface-guidelines/sign-in-with-apple
                                 btn_google_signin_dark.png       — from https://developers.google.com/identity/branding-guidelines -->
                            <StackLayout IsVisible="{Binding AuthViewModel.IsAuthenticated, Converter={StaticResource InvertedBoolConverter}}"
                                         Spacing="12">

                                <!-- Sign in with Microsoft (existing MSAL flow) -->
                                <Image Source="ms_symbollockup_signin_light.png"
                                       Aspect="AspectFit"
                                       HeightRequest="41"
                                       HorizontalOptions="Start">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignInMicrosoftTapped"/>
                                    </Image.GestureRecognizers>
                                </Image>

                                <!-- Sign in with Apple (External ID flow) -->
                                <Image Source="signin_with_apple.png"
                                       Aspect="AspectFit"
                                       HeightRequest="44"
                                       HorizontalOptions="Start">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignInAppleTapped"/>
                                    </Image.GestureRecognizers>
                                </Image>

                                <!-- Sign in with Google (External ID flow) -->
                                <!-- <Image Source="btn_google_signin_dark.png"
                                       Aspect="AspectFit"
                                       HeightRequest="40"
                                       HorizontalOptions="Start">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignInGoogleTapped"/>
                                    </Image.GestureRecognizers>
                                </Image> -->

                            </StackLayout>

                        </StackLayout>

                        <!-- Theme Selection -->
                        <Grid Grid.Row="1"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="8"
                              Padding="4,0,4,0">
                            <Label Grid.Column="0"
                                   Text="Theme"
                                   FontSize="14"
                                   TextColor="{DynamicResource Ink}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"/>

                            <Picker x:Name="ThemeColorPicker"
                                    Grid.Column="1"
                                    SelectedIndexChanged="OnThemeColorSelected"
                                    ItemsSource="{Binding AvailableThemes}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center"
                                    BackgroundColor="{DynamicResource WritingPaper}"
                                    TextColor="{DynamicResource Ink}"
                                    TitleColor="{DynamicResource Ink}"
                                    FontSize="18"/>
                        </Grid>

                        <!-- User Font Selection -->
                        <Grid Grid.Row="2"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="8"
                              Padding="4,0,4,0">
                            <Label Grid.Column="0"
                                   Text="User Font"
                                   FontSize="14"
                                   TextColor="{DynamicResource Ink}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"/>

                            <Picker x:Name="UserFontPicker"
                                    Grid.Column="1"
                                    SelectedIndexChanged="OnUserFontSelected"
                                    ItemsSource="{Binding AvailableUserFonts}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center"
                                    BackgroundColor="{DynamicResource WritingPaper}"
                                    TextColor="{DynamicResource Ink}"
                                    TitleColor="{DynamicResource Ink}"
                                    FontSize="18"/>
                        </Grid>

                        <Label Grid.Row="3"
                               Text="How to use Ben"
                               FontSize="14"
                               TextColor="{DynamicResource Link}"
                               TextDecorations="Underline"
                               HorizontalOptions="Center"
                               Padding="4,0,4,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnHelpTapped"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </Grid>

                </ScrollView>

                <BoxView Grid.Row="2"
                         Grid.ColumnSpan="2"
                         HeightRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

            </Grid>

            <!-- Action buttons -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,16,0,0">

                <Button Grid.Column="0"
                        Text="Cancel"
                        BackgroundColor="{DynamicResource Ink}"
                        TextColor="{DynamicResource WritingPaper}"
                        CornerRadius="4"
                        HeightRequest="44"
                        Clicked="OnCancelClicked"/>
                <Button Grid.Column="1"
                        Text="Save"
                        BackgroundColor="{DynamicResource Accent}"
                        TextColor="{DynamicResource WritingPaper}"
                        CornerRadius="4"
                        HeightRequest="44"
                        Clicked="OnSaveClicked"/>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
