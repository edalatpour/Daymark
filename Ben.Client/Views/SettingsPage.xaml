<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views"
             x:Class="Ben.Views.SettingsPage"
             x:DataType="views:SettingsPage"
             x:Name="RootSettingsPage"
             Title="Settings">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False"/>
    </Shell.BackButtonBehavior>

    <Grid Style="{DynamicResource PaperRootGrid}">

        <Grid Padding="{DynamicResource SpacingLg}"
              HorizontalOptions="Fill"
              RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="{DynamicResource SpacingMd}">

            <!-- Header -->
            <Label Grid.Row="0"
                   Text="Settings"
                   Style="{DynamicResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>

            <!-- Form -->
            <Border Grid.Row="2"
                    Style="{DynamicResource ThemedCard}"
                    StrokeThickness="{DynamicResource CardBorderThickness}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource ListCardCornerRadius}"/>
                </Border.StrokeShape>
                <ScrollView HorizontalOptions="Fill"
                            VerticalOptions="Fill">

                    <Grid BackgroundColor="{DynamicResource WritingPaper}"
                          Padding="{DynamicResource SpacingLg}"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="{DynamicResource SpacingLg}">

                        <!-- Authentication -->
                        <StackLayout Grid.Row="0"
                                     Spacing="{DynamicResource SpacingSm}"
                                     Padding="{DynamicResource SectionHeaderPadding}">

                            <!-- Not-authenticated state: available sign-in options -->
                            <!-- Image files required in Resources/Images:
                                 ms_symbollockup_signin_dark.png  — from https://learn.microsoft.com/en-us/entra/identity-platform/howto-add-branding-in-apps
                                   signin_with_apple.png            — from https://developer.apple.com/design/human-interface-guidelines/sign-in-with-apple -->

                            <VerticalStackLayout
                                IsVisible="{Binding AuthViewModel.IsAuthenticated, Converter={StaticResource InvertedBoolConverter}}"
                                Spacing="{DynamicResource SpacingMd}">

                                <!-- Sign in with Apple (External ID flow) -->
                                <Image Source="signin_with_apple.png"
                                       Aspect="AspectFit"
                                       WidthRequest="200"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignInAppleTapped"/>
                                    </Image.GestureRecognizers>
                                </Image>

                                <!-- Sign in with Microsoft (MSAL flow) -->
                                <Image Source="signin_with_microsoft.png"
                                       Aspect="AspectFit"
                                       WidthRequest="200"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignInMicrosoftTapped"/>
                                    </Image.GestureRecognizers>
                                </Image>

                            </VerticalStackLayout>

                        </StackLayout>

                        <!-- Theme Selection -->
                        <Grid Grid.Row="1"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="{DynamicResource SpacingSm}"
                              Padding="{DynamicResource SectionHeaderPadding}">
                            <Label Grid.Column="0"
                                   Text="Theme"
                                   Style="{DynamicResource LabelSection}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"/>

                            <Picker x:Name="ThemeColorPicker"
                                    Grid.Column="1"
                                    SelectedIndexChanged="OnThemeColorSelected"
                                    ItemsSource="{Binding AvailableThemes}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center"
                                    BackgroundColor="{DynamicResource WritingPaper}"
                                    TextColor="{DynamicResource Ink}"
                                    TitleColor="{DynamicResource Ink}"
                                    FontSize="18"/>
                        </Grid>

                        <Grid Grid.Row="2"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="{DynamicResource SpacingSm}"
                              Padding="{DynamicResource SectionHeaderPadding}">
                            <CheckBox x:Name="UseCustomBackgroundImageCheckBox"
                                      Grid.Column="0"
                                      VerticalOptions="Center"
                                      CheckedChanged="OnUseCustomBackgroundImageCheckedChanged"/>

                            <Label Grid.Column="1"
                                   Text="Use custom background image"
                                   Style="{DynamicResource LabelSection}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"/>

                            <Button x:Name="ChooseBackgroundImageButton"
                                    Grid.Column="2"
                                    Text="Choose file"
                                    Style="{DynamicResource GhostActionButton}"
                                    VerticalOptions="Center"
                                    Clicked="OnChooseBackgroundImageClicked"/>
                        </Grid>

                        <Label x:Name="CustomBackgroundImageFileNameLabel"
                               Grid.Row="3"
                               Text="No file selected"
                               FontSize="12"
                               TextColor="{DynamicResource Link}"
                               Padding="{DynamicResource SectionHeaderPadding}"
                               LineBreakMode="TailTruncation"/>

                        <!-- User Font Selection -->
                        <Grid Grid.Row="4"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="{DynamicResource SpacingSm}"
                              Padding="{DynamicResource SectionHeaderPadding}">
                            <Label Grid.Column="0"
                                   Text="User Font"
                                   Style="{DynamicResource LabelSection}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"/>

                            <Picker x:Name="UserFontPicker"
                                    Grid.Column="1"
                                    SelectedIndexChanged="OnUserFontSelected"
                                    ItemsSource="{Binding AvailableUserFonts}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center"
                                    BackgroundColor="{DynamicResource WritingPaper}"
                                    TextColor="{DynamicResource Ink}"
                                    TitleColor="{DynamicResource Ink}"
                                    FontSize="18"/>
                        </Grid>

                        <!-- Data & Privacy -->
                        <VerticalStackLayout Grid.Row="5"
                                             Spacing="{DynamicResource SpacingSm}"
                                             Padding="{DynamicResource SectionHeaderPadding}">
                            <Label Text="Data &amp; Privacy"
                                   Style="{DynamicResource LabelSection}"
                                   HorizontalOptions="Start"/>

                            <HorizontalStackLayout IsVisible="{Binding AuthViewModel.IsAuthenticated}"
                                                   Spacing="{DynamicResource SpacingSm}"
                                                   VerticalOptions="Center">
                                <Grid WidthRequest="24"
                                      HeightRequest="24"
                                      VerticalOptions="Center"
                                      HorizontalOptions="Center">
                                    <Border IsVisible="{Binding AuthViewModel.IsUserAvatarPhoto}"
                                            WidthRequest="24"
                                            HeightRequest="24"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Image Source="{Binding AuthViewModel.UserAvatarSource}"
                                               Aspect="AspectFill"
                                               WidthRequest="24"
                                               HeightRequest="24"/>
                                    </Border>

                                    <Image IsVisible="{Binding AuthViewModel.IsUserAvatarFallback}"
                                           Source="{Binding AuthViewModel.UserAvatarSource}"
                                           Aspect="AspectFit"
                                           WidthRequest="24"
                                           HeightRequest="24"/>
                                </Grid>

                                <Label Text="{Binding AuthViewModel.LoginStatusText}"
                                       FontSize="14"
                                       TextColor="{DynamicResource Link}"
                                       VerticalOptions="Center"
                                       LineBreakMode="WordWrap"/>
                            </HorizontalStackLayout>

                            <Button x:Name="SignOutButton"
                                    Text="Sign out"
                                    Style="{DynamicResource GhostActionButton}"
                                    IsVisible="{Binding AuthViewModel.IsAuthenticated}"
                                    Clicked="OnSignOutOnlyTapped"/>

                            <Label x:Name="LocalDataNoticeLabel"
                                   IsVisible="False"
                                   Text=""
                                   FontSize="12"
                                   TextColor="{DynamicResource Link}"
                                   LineBreakMode="WordWrap"/>

                            <Button x:Name="DeleteLocalDataButton"
                                    Text="Delete local data"
                                    Style="{DynamicResource GhostActionButton}"
                                    Clicked="OnDeleteLocalDataTapped"/>

                            <Button x:Name="DeleteCloudDataButton"
                                    Text="Delete cloud data (Delete account)"
                                    Style="{DynamicResource GhostActionButton}"
                                    IsVisible="{Binding AuthViewModel.IsAuthenticated}"
                                    Clicked="OnDeleteCloudDataTapped"/>

                            <HorizontalStackLayout x:Name="DeleteCloudBusyRow"
                                                   IsVisible="False"
                                                   Spacing="8"
                                                   VerticalOptions="Center">
                                <ActivityIndicator IsRunning="True"
                                                   WidthRequest="16"
                                                   HeightRequest="16"
                                                   Color="{DynamicResource Link}"/>
                                <Label Text="Deleting cloud data..."
                                       FontSize="12"
                                       TextColor="{DynamicResource Link}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Label Grid.Row="6"
                               Text="{Binding ApplicationDisplayVersion, StringFormat='Version: {0}'}"
                               FontSize="12"
                               TextColor="{DynamicResource Link}"
                               HorizontalOptions="Center"
                               Padding="{DynamicResource SectionHeaderPadding}"/>

                        <Label Grid.Row="7"
                               Text="About Daymark"
                               FontSize="14"
                               TextColor="{DynamicResource Link}"
                               TextDecorations="Underline"
                               HorizontalOptions="Center"
                               Padding="{DynamicResource SectionHeaderPadding}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnHelpTapped"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </Grid>

                </ScrollView>

            </Border>

            <!-- Action buttons -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="{DynamicResource SpacingMd}"
                  Margin="{DynamicResource FooterTopMargin}">

                <Button Grid.Column="0"
                        Text="Cancel"
                        Style="{DynamicResource SecondaryActionButton}"
                        Clicked="OnCancelClicked"/>
                <Button Grid.Column="1"
                        Text="Save"
                        Style="{DynamicResource PrimaryActionButton}"
                        Clicked="OnSaveClicked"/>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
