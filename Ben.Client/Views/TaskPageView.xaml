<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views"
             xmlns:viewModels="clr-namespace:Ben.ViewModels"
             xmlns:models="clr-namespace:Ben.Models"
             x:Class="Ben.Views.TaskPageView"
             x:DataType="viewModels:DailyViewModel">

    <Grid Padding="16"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="8">

        <!-- Date Header -->

        <VerticalStackLayout Spacing="0"
                             HorizontalOptions="Start"
                             VerticalOptions="Start">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnDateTapped"/>
            </VerticalStackLayout.GestureRecognizers>
            <Label Text="{Binding HeaderPrimaryText}"
                   Style="{StaticResource DateNumber}"
                   LineBreakMode="TailTruncation"
                   MaxLines="1"
                   HorizontalOptions="Fill"
                   HorizontalTextAlignment="Start"/>
            <Label Text="{Binding HeaderSecondaryText}"
                   IsVisible="{Binding ShowDateHeaderDetails}"
                   Style="{StaticResource DateText}"
                   HorizontalTextAlignment="Start"/>
            <Label Text="{Binding HeaderTertiaryText}"
                   IsVisible="{Binding ShowDateHeaderDetails}"
                   Style="{StaticResource DateText}"
                   HorizontalTextAlignment="Start"/>
        </VerticalStackLayout>

        <!-- Section Titles -->

        <Grid Grid.Row="1"
              ColumnDefinitions="36,34,*"
              ColumnSpacing="10"
              Padding="0,4,0,0">
            <Border Grid.Column="0"
                    Margin="0"
                    HeightRequest="32"
                    WidthRequest="32"
                    IsVisible="{Binding ShowDateHeaderDetails}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Stroke="{DynamicResource Ink}"
                    StrokeThickness="3">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="999"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCatchUpClicked"/>
                </Border.GestureRecognizers>
                <Label x:Name="CatchUpLabel"
                       Text="▼"
                       Style="{StaticResource SectionTitle}"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
            </Border>
            <Label Text="❖"
                   Grid.Column="1"
                   Style="{StaticResource SectionTitle}"
                   VerticalOptions="Center"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Tasks"
                   Grid.Column="2"
                   Style="{StaticResource SectionTitle}"
                   VerticalOptions="Center"
                   HorizontalTextAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="3"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <BoxView Grid.ColumnSpan="2"
                     HeightRequest="3"
                     BackgroundColor="{DynamicResource Ink}"/>
            <BoxView Grid.RowSpan="2"
                     WidthRequest="1"
                     BackgroundColor="{DynamicResource Ink}"/>

            <Grid Grid.Row="1"
                  Grid.Column="1"
                  BackgroundColor="{DynamicResource WritingPaper}"
                  RowDefinitions="*,Auto">
                <!-- iOS workaround: retained ListView is used here because CollectionView row measurement
                     and separator rendering became unstable across repeated date navigation. -->
                <ListView x:Name="TasksCollectionView"
                          Grid.Row="0"
                          Margin="0"
                          BackgroundColor="Transparent"
                          CachingStrategy="RetainElement"
                          HasUnevenRows="True"
                          SeparatorVisibility="None"
                          ItemsSource="{Binding CurrentDay.Tasks}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:TaskItem">
                            <ViewCell>
                                <ContentView BackgroundColor="{DynamicResource WritingPaper}">
                                    <Grid ColumnDefinitions="24,1,38,1,*"
                                          RowDefinitions="Auto,1"
                                          RowSpacing="0"
                                          ColumnSpacing="8"
                                          Padding="0,0,0,0"
                                          VerticalOptions="Start">
                                        <Grid.GestureRecognizers>
                                            <DragGestureRecognizer DragStarting="OnTaskDragStarting"/>
                                            <DropGestureRecognizer Drop="OnTaskDrop"/>
                                            <TapGestureRecognizer Tapped="OnTaskTapped"/>
                                        </Grid.GestureRecognizers>

                                        <Label Grid.Column="0"
                                               Text="{Binding StatusGlyph}"
                                               FontSize="20"
                                               HeightRequest="24"
                                               WidthRequest="24"
                                               Margin="{OnPlatform iOS='8,3,0,3', Default='8,2,0,3'}"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               VerticalOptions="Start"
                                               VerticalTextAlignment="Start"
                                               Style="{StaticResource Handwriting}"
                                               FontAttributes="Bold"/>

                                        <BoxView Grid.Column="1"
                                                 WidthRequest="1"
                                                 BackgroundColor="{DynamicResource Line}"/>
                                        <Label Grid.Column="2"
                                               Margin="{OnPlatform iOS='-5,0,-5,3', Default='-5,0,-5,3'}"
                                               Padding="0"
                                               Text="{Binding PriorityOrder}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Start"
                                               Style="{StaticResource Handwriting}"/>
                                        <BoxView Grid.Column="3"
                                                 WidthRequest="1"
                                                 BackgroundColor="{DynamicResource Line}"/>
                                        <Label Grid.Column="4"
                                               Margin="{OnPlatform iOS='0,0,0,3', Default='0,0,0,3'}"
                                               Padding="0"
                                               LineBreakMode="WordWrap"
                                               HorizontalTextAlignment="Start"
                                               VerticalTextAlignment="Start"
                                               Style="{StaticResource Handwriting}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Title}"
                                                          Style="{StaticResource Handwriting}"
                                                          TextColor="Black"/>
                                                    <Span Text="{Binding ForwardedFromDate, StringFormat=' ({0})', TargetNullValue=''}"
                                                          TextColor="{DynamicResource Accent}"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <BoxView Grid.Row="1"
                                                 Grid.ColumnSpan="5"
                                                 HeightRequest="1"
                                                 BackgroundColor="{DynamicResource Line}"
                                                 VerticalOptions="End"/>
                                    </Grid>
                                </ContentView>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Grid.Row="1"
                      RowDefinitions="1,Auto"
                      ColumnDefinitions="24,1,38,1,*"
                      ColumnSpacing="8"
                      Padding="0,0,0,0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddTaskTapped"/>
                    </Grid.GestureRecognizers>
                    <BoxView Grid.Row="0"
                             Grid.ColumnSpan="5"
                             HeightRequest="1"
                             BackgroundColor="{DynamicResource Line}"/>
                    <Image Grid.Row="1"
                           Grid.Column="0"
                           Source="plus.webp"
                           HeightRequest="24"
                           WidthRequest="24"
                           Margin="8,3,0,0"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <BoxView Grid.Row="1"
                             Grid.Column="1"
                             WidthRequest="1"
                             BackgroundColor="{DynamicResource Line}"/>
                    <BoxView Grid.Row="1"
                             Grid.Column="3"
                             WidthRequest="1"
                             BackgroundColor="{DynamicResource Line}"/>
                    <Label Grid.Row="1"
                           Grid.Column="4"
                           Text="New task..."
                           VerticalTextAlignment="Center"
                           Style="{StaticResource Handwriting}"
                           FontAttributes="Italic"
                           TextColor="{DynamicResource Line}"/>
                </Grid>
            </Grid>

            <BoxView Grid.Row="1"
                     Grid.ColumnSpan="2"
                     HeightRequest="1"
                     BackgroundColor="{DynamicResource Ink}"
                     VerticalOptions="End"/>
        </Grid>

    </Grid>

</ContentView>
