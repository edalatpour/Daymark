<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views"
             xmlns:viewModels="clr-namespace:Ben.ViewModels"
             xmlns:models="clr-namespace:Ben.Models"
             x:Class="Ben.Views.NotesPageView"
             x:DataType="viewModels:DailyViewModel">

    <Grid Padding="{DynamicResource SpacingLg}"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="{DynamicResource SpacingSm}">

        <!-- Date Header -->

        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="12"
              HorizontalOptions="Fill"
              VerticalOptions="Start">

            <Label Grid.Column="0"
                   Text="{Binding DailyQuote}"
                   IsVisible="{Binding ShowDailyQuote}"
                   Style="{StaticResource DateText}"
                   FontSize="12"
                   MaxLines="7"
                   LineBreakMode="WordWrap"
                   HorizontalOptions="Fill"
                   HorizontalTextAlignment="Start"
                   VerticalOptions="Start"/>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="0"
                                 HorizontalOptions="End"
                                 VerticalOptions="Start">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDateTapped"/>
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="{Binding HeaderPrimaryText}"
                       Style="{StaticResource DateNumber}"
                       LineBreakMode="TailTruncation"
                       MaxLines="1"
                       HorizontalOptions="Fill"
                       HorizontalTextAlignment="End"/>
                <Label Text="{Binding HeaderSecondaryText}"
                       IsVisible="{Binding ShowDateHeaderDetails}"
                       Style="{StaticResource DateText}"
                       HorizontalTextAlignment="End"/>
                <Label Text="{Binding HeaderTertiaryText}"
                       IsVisible="{Binding ShowDateHeaderDetails}"
                       Style="{StaticResource DateText}"
                       HorizontalTextAlignment="End"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Section Titles -->

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto,*"
              ColumnSpacing="10"
              Padding="{DynamicResource SectionHeaderPadding}">
            <Label Grid.Column="1"
                   Text="Notes"
                   Style="{StaticResource LabelTitle}"
                   VerticalOptions="Center"
                   HorizontalTextAlignment="Center"/>
            <Border Grid.Column="2"
                    HeightRequest="32"
                    WidthRequest="32"
                    HorizontalOptions="End"
                    VerticalOptions="Center"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="{DynamicResource BorderThickness}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="999"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSearchTapped"/>
                </Border.GestureRecognizers>
                <Label Text="⌕"
                       Style="{StaticResource SectionTitle}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="3"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <BoxView Grid.ColumnSpan="2"
                     Style="{StaticResource DividerStrong}"/>
            <BoxView Grid.RowSpan="2"
                     Style="{StaticResource GridLineStrong}"/>

            <Grid Grid.Row="1"
                  Grid.Column="1"
                  BackgroundColor="{DynamicResource WritingPaper}"
                  RowDefinitions="*,Auto">
                <!-- iOS workaround: retained ListView is used here because CollectionView row measurement
                     and separator rendering became unstable across repeated date navigation. -->
                <ListView x:Name="NotesCollectionView"
                          Grid.Row="0"
                          Margin="0"
                          BackgroundColor="Transparent"
                          CachingStrategy="RetainElement"
                          HasUnevenRows="True"
                          SeparatorVisibility="None"
                          ItemsSource="{Binding CurrentDay.Notes}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:NoteItem">
                            <ViewCell>
                                <ContentView BackgroundColor="{DynamicResource WritingPaper}">
                                    <Grid ColumnDefinitions="32,1,*"
                                          RowDefinitions="Auto,1"
                                          RowSpacing="0"
                                          ColumnSpacing="8"
                                          Padding="0,0,0,0"
                                          VerticalOptions="Start">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnNoteTapped"/>
                                        </Grid.GestureRecognizers>
                                        <Label Grid.Column="0"
                                               Text="{Binding Order}"
                                               Margin="{OnPlatform iOS='-5,0,-5,3', Default='-5,0,-5,3'}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Start"
                                               Style="{StaticResource Handwriting}"/>
                                        <BoxView Grid.Column="1"
                                                 Style="{StaticResource GridLineSoft}"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Fill"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding Text}"
                                               Margin="{OnPlatform iOS='0,0,0,3', Default='0,0,0,3'}"
                                               LineBreakMode="WordWrap"
                                               HorizontalTextAlignment="Start"
                                               VerticalTextAlignment="Start"
                                               Style="{StaticResource Handwriting}"/>
                                        <BoxView Grid.Row="1"
                                                 Grid.ColumnSpan="3"
                                                 Style="{StaticResource DividerSoft}"
                                                 VerticalOptions="End"/>
                                    </Grid>
                                </ContentView>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Grid.Row="1"
                      RowDefinitions="1,Auto"
                      ColumnDefinitions="32,1,*"
                      ColumnSpacing="8"
                      Padding="0,0,0,0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddNoteTapped"/>
                    </Grid.GestureRecognizers>
                    <BoxView Grid.Row="0"
                             Grid.ColumnSpan="3"
                             Style="{StaticResource DividerSoft}"/>
                    <Image Grid.Row="1"
                           Grid.Column="0"
                           Source="plus.webp"
                           HeightRequest="24"
                           WidthRequest="24"
                           Margin="8,3,0,0"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <BoxView Grid.Row="1"
                             Grid.Column="1"
                             Style="{StaticResource GridLineSoft}"
                             HorizontalOptions="Center"
                             VerticalOptions="Fill"/>
                    <Label Grid.Row="1"
                           Grid.Column="2"
                           Text="New note..."
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="Start"
                           Style="{StaticResource Handwriting}"
                           FontAttributes="Italic"
                           TextColor="{DynamicResource Line}"/>
                </Grid>
            </Grid>

            <BoxView Grid.Row="1"
                     Grid.ColumnSpan="2"
                     Style="{StaticResource DividerStrong}"
                     VerticalOptions="End"/>
        </Grid>
    </Grid>
</ContentView>
