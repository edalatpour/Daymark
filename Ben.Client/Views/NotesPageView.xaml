<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views;assembly=Ben.Client"
             xmlns:viewModels="clr-namespace:Ben.ViewModels"
             xmlns:models="clr-namespace:Ben.Models"
             x:Class="Ben.Views.NotesPageView"
             x:DataType="viewModels:DailyViewModel"
             Background="Transparent">

    <Grid Background="Transparent"
          SafeAreaEdges="All">

        <Grid Background="Transparent"
              Padding="{DynamicResource SpacingLg}"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="{DynamicResource SpacingSm}">

            <!-- Date Header -->

            <Grid ColumnDefinitions="Auto,Auto"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="4"
                  HorizontalOptions="End"
                  VerticalOptions="Start">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDateTapped"/>
                </Grid.GestureRecognizers>

                <VerticalStackLayout Grid.Column="0"
                                     Grid.Row="0"
                                     Spacing="0"
                                     Padding="0,0,2,0"
                                     HorizontalOptions="End"
                                     VerticalOptions="Center">
                    <Label Text="{Binding HeaderSecondaryText}"
                           IsVisible="{Binding ShowDateHeaderDetails}"
                           Style="{DynamicResource DaymarkDateMeta}"
                           HorizontalTextAlignment="End"/>
                    <Label Text="{Binding HeaderTertiaryText}"
                           IsVisible="{Binding ShowDateHeaderDetails}"
                           Style="{DynamicResource DaymarkDateMeta}"
                           HorizontalTextAlignment="End"/>
                </VerticalStackLayout>

                <Grid Grid.Column="1"
                      Grid.Row="0"
                      HorizontalOptions="End"
                      VerticalOptions="End">
                    <!-- <Border Style="{DynamicResource DaymarkHeaderBand}"/> -->

                    <Border Margin="0,8,0,4"
                            WidthRequest="84"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            Style="{DynamicResource DaymarkDateBadge}">
                        <Label Text="{Binding HeaderPrimaryText}"
                               Style="{DynamicResource DaymarkDateNumber}"
                               LineBreakMode="NoWrap"
                               MaxLines="1"/>
                    </Border>
                </Grid>

                <BoxView Grid.Row="1"
                         Grid.ColumnSpan="2"
                         Style="{DynamicResource DaymarkHeaderRule}"/>
            </Grid>

            <!-- Section Titles -->

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto,*"
                  ColumnSpacing="10"
                  Padding="{DynamicResource SectionHeaderPadding}">
                <Label Grid.Column="1"
                       Text="Notes"
                       Style="{DynamicResource SectionTitle}"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"/>
                <Border Grid.Column="2"
                        HeightRequest="32"
                        WidthRequest="32"
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="{DynamicResource BorderThickness}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="999"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="⌕"
                           Style="{StaticResource SectionTitle}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"/>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Style="{DynamicResource TranslucentThemedCard}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource ListCardCornerRadius}"/>
                </Border.StrokeShape>

                <Grid Style="{DynamicResource TranslucentCardHostGrid}"
                      RowDefinitions="*,Auto">
                    <BoxView Grid.RowSpan="2"
                             Style="{DynamicResource TranslucentCardOverlay}"/>

                    <!-- iOS workaround: retained ListView is used here because CollectionView row measurement
                     and separator rendering became unstable across repeated date navigation. -->
                    <ListView x:Name="NotesCollectionView"
                              Grid.Row="0"
                              Margin="0"
                              BackgroundColor="Transparent"
                              CachingStrategy="RetainElement"
                              HasUnevenRows="True"
                              SeparatorVisibility="None"
                              ItemsSource="{Binding CurrentDay.Notes}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:NoteItem">
                                <views:AutoSizingViewCell>
                                    <ContentView Style="{DynamicResource OpaqueListRowSurface}">
                                        <Grid ColumnDefinitions="28,*"
                                              RowDefinitions="Auto,1"
                                              RowSpacing="0"
                                              ColumnSpacing="10"
                                              Padding="0,0,0,0"
                                              VerticalOptions="Start">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnNoteTapped"/>
                                            </Grid.GestureRecognizers>
                                            <Label Grid.Column="0"
                                                   Text="{Binding Order}"
                                                   Margin="{OnPlatform iOS='0,2,0,3', Default='0,2,0,3'}"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Start"
                                                   Style="{StaticResource Handwriting}"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding Text}"
                                                   Margin="{OnPlatform iOS='0,2,0,3', Default='0,2,0,3'}"
                                                   LineBreakMode="WordWrap"
                                                   HorizontalTextAlignment="Start"
                                                   VerticalTextAlignment="Start"
                                                   Style="{StaticResource Handwriting}"/>
                                            <BoxView Grid.Row="1"
                                                     Grid.ColumnSpan="2"
                                                     Style="{DynamicResource DividerSoft}"
                                                     VerticalOptions="End"/>
                                        </Grid>
                                    </ContentView>
                                </views:AutoSizingViewCell>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="1"
                          RowDefinitions="1,Auto"
                          ColumnDefinitions="28,*"
                          Style="{DynamicResource OpaqueListFooterSurface}"
                          ColumnSpacing="10"
                          Padding="0,0,0,0">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAddNoteTapped"/>
                        </Grid.GestureRecognizers>
                        <BoxView Grid.Row="0"
                                 Grid.ColumnSpan="2"
                                 Style="{DynamicResource DividerSoft}"/>
                        <Image Grid.Row="1"
                               Grid.Column="0"
                               Source="plus.webp"
                               HeightRequest="24"
                               WidthRequest="24"
                               Margin="8,3,0,0"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                        <Label Grid.Row="1"
                               Grid.Column="1"
                               Text="New note..."
                               VerticalTextAlignment="Center"
                               HorizontalTextAlignment="Start"
                               Style="{StaticResource Handwriting}"
                               FontAttributes="Italic"
                               TextColor="{DynamicResource Line}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentView>
