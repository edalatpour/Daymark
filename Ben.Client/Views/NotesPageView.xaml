<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views"
             xmlns:viewModels="clr-namespace:Ben.ViewModels"
             xmlns:models="clr-namespace:Ben.Models"
             x:Class="Ben.Views.NotesPageView"
             x:DataType="viewModels:DailyViewModel">

    <Grid Padding="{DynamicResource SpacingLg}"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="{DynamicResource SpacingSm}">

        <!-- Date Header -->

        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="12"
              HorizontalOptions="Fill"
              VerticalOptions="Start">

            <Label Grid.Column="0"
                   Text="{Binding DailyQuote}"
                   IsVisible="{Binding ShowDailyQuote}"
                   Style="{DynamicResource DateText}"
                   FontSize="12"
                   MaxLines="7"
                   LineBreakMode="WordWrap"
                   HorizontalOptions="Fill"
                   HorizontalTextAlignment="Start"
                   VerticalOptions="Start"/>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="4"
                  HorizontalOptions="End"
                  VerticalOptions="Start">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDateTapped"/>
                </Grid.GestureRecognizers>

                <Grid Grid.Row="0"
                      WidthRequest="220"
                      HeightRequest="72">
                    <Border Style="{DynamicResource DaymarkHeaderBand}"/>

                    <Grid InputTransparent="True"
                          Margin="0,4,0,4">
                        <BoxView Style="{DynamicResource HeaderPatternStripe}"
                                 HeightRequest="{DynamicResource PatternStripeWidth}"
                                 Rotation="{DynamicResource PatternAngle}"
                                 VerticalOptions="Start"
                                 Margin="0,10,0,0"/>
                        <BoxView Style="{DynamicResource HeaderPatternStripe}"
                                 HeightRequest="{DynamicResource PatternStripeWidth}"
                                 Rotation="{DynamicResource PatternAngle}"
                                 VerticalOptions="Center"/>
                        <BoxView Style="{DynamicResource HeaderPatternStripe}"
                                 HeightRequest="{DynamicResource PatternStripeWidth}"
                                 Rotation="{DynamicResource PatternAngle}"
                                 VerticalOptions="End"
                                 Margin="0,0,0,10"/>

                        <BoxView Style="{DynamicResource HeaderPatternStripe}"
                                 HeightRequest="{DynamicResource PatternStripeWidth}"
                                 Rotation="{DynamicResource PatternSecondaryAngle}"
                                 Opacity="{DynamicResource PatternSecondaryOpacity}"
                                 VerticalOptions="Start"
                                 Margin="0,10,0,0"/>
                        <BoxView Style="{DynamicResource HeaderPatternStripe}"
                                 HeightRequest="{DynamicResource PatternStripeWidth}"
                                 Rotation="{DynamicResource PatternSecondaryAngle}"
                                 Opacity="{DynamicResource PatternSecondaryOpacity}"
                                 VerticalOptions="Center"/>
                        <BoxView Style="{DynamicResource HeaderPatternStripe}"
                                 HeightRequest="{DynamicResource PatternStripeWidth}"
                                 Rotation="{DynamicResource PatternSecondaryAngle}"
                                 Opacity="{DynamicResource PatternSecondaryOpacity}"
                                 VerticalOptions="End"
                                 Margin="0,0,0,10"/>
                    </Grid>

                    <Border Margin="0,8,10,8"
                            WidthRequest="84"
                            HorizontalOptions="End"
                            Style="{DynamicResource DaymarkDateBadge}">
                        <Label Text="{Binding HeaderPrimaryText}"
                               Style="{DynamicResource DaymarkDateNumber}"
                               LineBreakMode="NoWrap"
                               MaxLines="1"/>
                    </Border>

                    <BoxView Style="{DynamicResource DaymarkHeaderRule}"/>
                </Grid>

                <VerticalStackLayout Grid.Row="1"
                                     Spacing="0"
                                     Padding="0,0,2,0">
                    <Label Text="{Binding HeaderSecondaryText}"
                           IsVisible="{Binding ShowDateHeaderDetails}"
                           Style="{DynamicResource DaymarkDateMeta}"
                           HorizontalTextAlignment="End"/>
                    <Label Text="{Binding HeaderTertiaryText}"
                           IsVisible="{Binding ShowDateHeaderDetails}"
                           Style="{DynamicResource DaymarkDateMeta}"
                           HorizontalTextAlignment="End"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Section Titles -->

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto,*"
              ColumnSpacing="10"
              Padding="{DynamicResource SectionHeaderPadding}">
            <Label Grid.Column="1"
                   Text="Notes"
                   Style="{DynamicResource SectionTitle}"
                   VerticalOptions="Center"
                   HorizontalTextAlignment="Center"/>
            <Border Grid.Column="2"
                    HeightRequest="32"
                    WidthRequest="32"
                    HorizontalOptions="End"
                    VerticalOptions="Center"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="{DynamicResource BorderThickness}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="999"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSearchTapped"/>
                </Border.GestureRecognizers>
                <Label Text="⌕"
                       Style="{StaticResource SectionTitle}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{DynamicResource ThemedCard}"
                StrokeThickness="{DynamicResource DividerThickness}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="{DynamicResource ListCardCornerRadius}"/>
            </Border.StrokeShape>

            <Grid BackgroundColor="{DynamicResource WritingPaper}"
                  RowDefinitions="*,Auto">
                <!-- iOS workaround: retained ListView is used here because CollectionView row measurement
                     and separator rendering became unstable across repeated date navigation. -->
                <ListView x:Name="NotesCollectionView"
                          Grid.Row="0"
                          Margin="0"
                          BackgroundColor="Transparent"
                          CachingStrategy="RetainElement"
                          HasUnevenRows="True"
                          SeparatorVisibility="None"
                          ItemsSource="{Binding CurrentDay.Notes}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:NoteItem">
                            <ViewCell>
                                <ContentView BackgroundColor="{DynamicResource WritingPaper}">
                                    <Grid ColumnDefinitions="28,*"
                                          RowDefinitions="Auto,1"
                                          RowSpacing="0"
                                          ColumnSpacing="10"
                                          Padding="0,0,0,0"
                                          VerticalOptions="Start">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnNoteTapped"/>
                                        </Grid.GestureRecognizers>
                                        <Label Grid.Column="0"
                                               Text="{Binding Order}"
                                               HorizontalTextAlignment="End"
                                               VerticalTextAlignment="Start"
                                               FontFamily="{DynamicResource ThemeDateDayFont}"
                                               FontSize="13"
                                               TextColor="{DynamicResource SecondaryInkBrush}"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding Text}"
                                               Margin="{OnPlatform iOS='0,0,0,3', Default='0,0,0,3'}"
                                               LineBreakMode="WordWrap"
                                               HorizontalTextAlignment="Start"
                                               VerticalTextAlignment="Start"
                                               Style="{StaticResource Handwriting}"/>
                                        <BoxView Grid.Row="1"
                                                 Grid.ColumnSpan="2"
                                                 Style="{DynamicResource DividerSoft}"
                                                 VerticalOptions="End"/>
                                    </Grid>
                                </ContentView>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Grid.Row="1"
                      RowDefinitions="1,Auto"
                      ColumnDefinitions="28,*"
                      ColumnSpacing="10"
                      Padding="0,0,0,0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddNoteTapped"/>
                    </Grid.GestureRecognizers>
                    <BoxView Grid.Row="0"
                             Grid.ColumnSpan="2"
                             Style="{DynamicResource DividerSoft}"/>
                    <Image Grid.Row="1"
                           Grid.Column="0"
                           Source="plus.webp"
                           HeightRequest="24"
                           WidthRequest="24"
                           Margin="8,3,0,0"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Text="New note..."
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="Start"
                           Style="{StaticResource Handwriting}"
                           FontAttributes="Italic"
                           TextColor="{DynamicResource Line}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>
