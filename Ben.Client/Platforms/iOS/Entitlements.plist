<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>keychain-access-groups</key>
    <array>
        <!-- Required by MSAL: WithIosKeychainSecurityGroup("com.edalatpour.Ben") in AuthenticationService -->
        <string>$(AppIdentifierPrefix)com.edalatpour.Ben</string>
        <!-- Retained for MSAL ADAL cache interop -->
        <string>$(AppIdentifierPrefix)com.microsoft.adalcache</string>
    </array>
</dict>
</plist>
